APP_NAME="Monsoon Preparedness API"
APP_ENV=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,https://monsoon-preparedness-app-s6kv.vercel.app

